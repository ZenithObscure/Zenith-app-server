{
  "name": "zenith-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron-out/main.js",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:api": "tsx backend/src/index.ts",
    "dev:desktop": "npm run build:electron-main && electron .",
    "start:api": "node backend/dist/index.js",
    "build": "tsc -b && vite build",
    "build:api": "tsc -p backend/tsconfig.json",
    "build:electron": "vite build --mode electron",
    "build:electron-main": "tsc -p tsconfig.electron.json",
    "build:electron-all": "npm run build:electron && npm run build:electron-main",
    "dist:electron": "npm run build:electron-all && electron-builder",
    "dist:electron:linux": "npm run build:electron-all && electron-builder --linux",
    "dist:electron:win": "npm run build:electron-all && electron-builder --win",
    "dist:electron:mac": "npm run build:electron-all && electron-builder --mac",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.4.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.1.7"
  }
}
